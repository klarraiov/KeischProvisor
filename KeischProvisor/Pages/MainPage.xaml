<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="KeischProvisor.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KeischProvisor.Pages"
    xmlns:navinfo="using:KeischProvisor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:communitytoolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menubar -->
        <Grid x:Name="MenuBarGrid" Grid.Row="0" Margin="0 -8 0 0" Visibility="Visible">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- leftside -->
            <MenuBar Grid.Row="0" Grid.Column="0">
                <MenuBarItem x:Uid="MainPage_MenuFile" Title="File">
                    <MenuFlyoutItem x:Uid="MainPage_MenuFileOpen" Text="Open" Click="MainPage_MenuFileOpenMenuFlyoutItem_Click"/>
                    <MenuFlyoutItem x:Uid="MainPage_MenuFileSave" Text="Save" />
                    <MenuFlyoutItem x:Uid="MainPage_MenuFileExit" Text="Exit" />
                </MenuBarItem>
                <MenuBarItem x:Uid="MainPage_MenuEdit" Title="Edit">
                    <MenuFlyoutItem x:Uid="MainPage_MenuEditCut" Text="Cut" />
                    <MenuFlyoutItem x:Uid="MainPage_MenuEditCopy" Text="Copy" />
                    <MenuFlyoutItem x:Uid="MainPage_MenuEditPaste" Text="Paste" />
                </MenuBarItem>
                <MenuBarItem x:Uid="MainPage_MenuView" Title="View">
                    <ToggleMenuFlyoutItem x:Name="MainPage_StatusBarToggleMenuFlyoutItem" x:Uid="MainPage_MenuViewStatusBar" Text="Status bar" Click="StatusBarToggleMenuFlyoutItem_Click"/>
                </MenuBarItem>
            </MenuBar>

            <!-- rightside -->
            <Button Height="32" Margin="0 0 4 0" Grid.Row="0" Grid.Column="1" Background="Transparent" BorderBrush="Transparent" Click="SettingsButton_Click" >
                <Grid>
                    <FontIcon FontSize="14" Glyph="&#xe713;"/>
                </Grid>
            </Button>
        </Grid>

        <!-- Main -->
        <Grid Grid.Row="1" x:Name="MainPage_MainGrid" Background="{ThemeResource LayerFillColorDefault}" Margin="0" ChildrenTransitions="{StaticResource GeneralAnimations}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <communitytoolkit:WrapPanel Grid.Row="0" Grid.Column="0" Margin="10 8 0 0" Orientation="Horizontal" Background="Transparent" ChildrenTransitions="{StaticResource GeneralAnimations}">
                <StackPanel Orientation="Horizontal" Margin="0 0 16 0">
                    <TextBlock x:Uid="MainPage_MainGrid_SignatureTextBlock" Text="Signature: " Opacity="0.7" xml:space="preserve"/>
                    <TextBlock x:Name="MainPage_MainGrid_SignatureTextBlock" Text="—"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 16 0">
                    <TextBlock x:Uid="MainPage_MainGrid_BuildTextBlock" Text="Build: " Opacity="0.7" xml:space="preserve"/>
                    <TextBlock x:Name="MainPage_MainGrid_BuildTextBlock" Text="—"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 16 0">
                    <TextBlock x:Uid="MainPage_MainGrid_ChecksumTextBlock" Text="Checksum: " Opacity="0.7" xml:space="preserve"/>
                    <TextBlock x:Name="MainPage_MainGrid_ChecksumTextBlock" Text="—"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0 0 16 0">
                    <TextBlock x:Uid="MainPage_MainGrid_TopHeadersCountTextBlock" Text="Top Headers Count: " Opacity="0.7" xml:space="preserve"/>
                    <TextBlock x:Name="MainPage_MainGrid_TopHeadersCountTextBlock" Text="—"/>
                </StackPanel>
            </communitytoolkit:WrapPanel>

            <ListView ScrollViewer.VerticalScrollBarVisibility="Hidden" ItemContainerTransitions="{StaticResource GeneralAnimations}" Transitions="{StaticResource GeneralAnimations}" Visibility="Visible" Grid.Row="1" Grid.Column="0" ItemsSource="{x:Bind navigationLists}" SelectionMode="None" Margin="0 10 0 0" ItemContainerStyle="{StaticResource DefaultListViewItemStyle_Catrified}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:TopHeaderNavigationInfo">
                        <communitytoolkit:SettingsCard Header="{x:Bind HeaderName}" Description="{x:Bind ResolvedName}" IsClickEnabled="True" BorderThickness="0" Margin="0 0 0 2" Click="SettingsCard_Click"></communitytoolkit:SettingsCard>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!--<ScrollViewer Visibility="Collapsed" Grid.Row="1" Grid.Column="0" Margin="0 10 0 0">
                <Grid x:Name="testui" Margin="10 0 10 10" ChildrenTransitions="{StaticResource GeneralAnimations}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                </Grid>
            </ScrollViewer>-->
        </Grid>


        <!-- Status Bar-->
        <Grid  Visibility="Visible" x:Name="StatusBar" Grid.Row="2"  Height="32">
            <TextBlock x:Uid="MainPage_StatusBarTextBlock" x:Name="StatusBarText" VerticalAlignment="Center" Margin="8,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
        </Grid>
    </Grid>
</Page>
